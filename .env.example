# ─── Claude (required) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=12000
TRANSCRIPT_RESEARCH_CHARS=18000

# ─── OpenAI (premium final review — recommended for production) ───────────────
OPENAI_API_KEY=
OPENAI_REVIEW_MODEL=gpt-5.5
# Set to false to skip OpenAI gates (not recommended for production premium episodes)
OPENAI_REVIEW_ENABLED=true
OPENAI_REPAIR_ENABLED=true
OPENAI_REPAIR_MAX_CHUNKS=6

# Premium retention / long transcript automation
# Transcripts longer than this (chars) auto-switch to segmented fact extraction in premium mode
PREMIUM_SEGMENTED_FACT_LOCK_THRESHOLD=30000

# ─── ElevenLabs (optional — needed for enable_voice=true) ─────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_NARRATOR_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ─── Asset APIs (optional — needed for enable_assets=true) ────────────────────
PEXELS_API_KEY=
PIXABAY_API_KEY=

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ─── Pipeline control ─────────────────────────────────────────────────────────
MAX_REPAIR_PASSES=1
MIN_ACCEPTABLE_DURATION_RATIO=0.8
# Estimated words-per-minute for Hindi true-crime narration (slow, deliberate delivery ≈ 110 wpm)
# Used by the quality critic to calculate script duration from word count.
# Typical Hindi podcast narration is 130–150 wpm; true-crime tone is slower.
HINDI_NARRATION_WPM=110

# Fact-lock extraction mode
#   research_view  — single Claude call using beginning/middle/end transcript view (default, cheaper)
#   segmented      — splits transcript into ~7000-char segments, extracts per segment, then merges
#                    Use for very long or complex transcripts where mid-section details matter.
FACT_LOCK_MODE=research_view
FACT_LOCK_SEGMENT_CHARS=7000

# Idempotent stage execution
#   false  — always re-run every stage (default)
#   true   — skip a stage if its output file already exists (saves cost when debugging a later stage)
REUSE_EXISTING_STAGE_OUTPUTS=false

# Script chunk writer control
SCRIPT_CHUNK_RETRY_LIMIT=1   # retries per chunk (0 = try once, 1 = try twice)
MAX_SCRIPT_CHUNKS=16
MIN_SCRIPT_CHUNKS=10

# ─── Quality / cost control ───────────────────────────────────────────────────
# Quality mode — controls which review gates run
#   premium_final  — Claude + Python + OpenAI; required before ElevenLabs (default)
#   premium_build  — Claude + Python only; useful for script debugging; NOT voice-ready
#   premium_batch  — no OpenAI gates; for bulk candidate evaluation; NOT voice-ready
QUALITY_MODE=premium_final

# OpenAI review policy (only applies when QUALITY_MODE=premium_final)
#   adaptive  — run Hindi Editor gate only (Stage 14); saves 1 OpenAI call per episode (default)
#   always    — run both Hindi Editor + Originality/YT Risk gates (maximum coverage)
#   disabled  — skip all OpenAI gates (not blocking, lowers confidence — not recommended for production)
OPENAI_REVIEW_POLICY=adaptive

# Skip all premium quality gates — FOR DEBUGGING SCRIPT GENERATION ONLY
# safe_to_voice is permanently False when this is true. Remove before audio production.
SKIP_FINAL_GATES=false

# Claude prompt caching — reduces cost and latency on repeated runs with stable system instructions
# Uses Anthropic prompt-caching beta (cache_control: ephemeral) on system messages.
# Set to false to disable prompt caching (useful for debugging prompt changes).
CLAUDE_PROMPT_CACHE_ENABLED=false
# TTL hint for prompt cache entries (informational — Anthropic controls actual TTL)
CLAUDE_PROMPT_CACHE_TTL=5m

# Cost / budget guards — pipeline aborts with BudgetExceededError if these are exceeded
# MAX_TOTAL_MODEL_CALLS: hard cap across all Claude + OpenAI calls in one pipeline run
# MAX_REPAIR_CALLS: cap on Claude repair-stage calls (targeted chunk repair, copyedit repair, etc.)
# MAX_OPENAI_REPAIR_CALLS: cap on OpenAI targeted chunk repair calls
# Phase 1 testing: set high so limits never block a run. Tighten after baseline data.
MAX_TOTAL_MODEL_CALLS=999
MAX_REPAIR_CALLS=999
MAX_OPENAI_REPAIR_CALLS=999
# Soft caps for failed late-stage repair paths. If exceeded, the run stops
# not_voice_ready_auto_retry_exhausted instead of spending more rescue calls.
FAILED_PATH_MAX_CLAUDE_REPAIR_CALLS=12
FAILED_PATH_MAX_OPENAI_REPAIR_CALLS=4

# Set to true to enable POST /api/episodes/full (not production-ready — use /api/episodes/package first)
# Only enable after confirming safe_to_voice=true from /api/episodes/package
ENABLE_FULL_PIPELINE=false

# ─── Originality transformation ───────────────────────────────────────────────
# Run the Originality Transformation Planner before script outline.
# Produces 02-facts/originality_transformation_plan.json.
# Tells the script writer how to create an original Hindi episode, not a translation.
# Failure is non-fatal but sets safe_to_voice=False.
# Default true — set false only for debugging script structure (not production).
ORIGINALITY_TRANSFORMATION_ENABLED=true

# Maximum high-risk (≥8-word verbatim) source phrase matches allowed before safe_to_voice=False.
# 0 = strict mode (any verbatim long phrase from source blocks approval).
# Increase only for specific cases where long proper-noun phrases are unavoidable.
SOURCE_SIMILARITY_MAX_HIGH_RISK_MATCHES=0

# ─── Repair routing and auto-rebuild ──────────────────────────────────────────
# Claude repair policy
#   grouped_root_cause  — group many issues into root causes; repair root causes (cheaper, default)
#   per_chunk           — repair every individual chunk (legacy, expensive)
CLAUDE_REPAIR_POLICY=grouped_root_cause
# Max grouped root-cause targets per Claude repair round (stop if more)
MAX_CLAUDE_REPAIR_TARGETS_PER_ROUND=4
# Max Claude repair rounds (1 = one grouped pass, then stop)
MAX_CLAUDE_REPAIR_ROUNDS=1
# When true, run Claude premium section rebuild when OAI final gate finds too many targets
AUTO_REBUILD_ENABLED=true
MAX_AUTO_REBUILD_ROUNDS=1
MAX_AUTO_REBUILD_TARGETS=12

# OpenAI targeted cluster repair rescue.
# Used only after one Claude grouped repair leaves the same source-copy /
# reconstruction / sensitive-safety blocker unresolved. Final approval still
# requires OpenAI Final Premium Gate.
OPENAI_CLUSTER_REPAIR_ENABLED=true
MAX_OPENAI_CLUSTER_REPAIR_CHUNKS=4
MAX_OPENAI_CLUSTER_REPAIR_ROUNDS=1
